{"expires":1778489154,"content":"<!DOCTYPE html>\n<html lang=\"en\" class=\"scroll-smooth\">\n\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>\n        Properties \u2014 Advet Buildwell    <\/title>\n    <meta name=\"description\"\n        content=\"Browse Advet Buildwell&#039;s curated collection of active property listings.\">\n        <script src=\"\/advet\/assets\/js\/tailwind.min.js\"><\/script>\n    <script>\n        tailwind.config = {\n            theme: {\n                extend: {\n                    colors: {\n                        background: '#ffffff', foreground: '#2a2925',\n                        muted: '#6d685c', surface: '#f4f0e6',\n                        accent: { DEFAULT: '#899178', dark: '#6e755f' },\n                        sand: '#dfd8cc'\n                    },\n                    fontFamily: {\n                        sans: ['\"Outfit\"', 'system-ui', 'sans-serif'],\n                        serif: ['\"Cormorant Garamond\"', 'Playfair Display', 'serif'],\n                    },\n                    borderRadius: { '4xl': '2rem' },\n                    transitionTimingFunction: { 'soft': 'cubic-bezier(0.4, 0, 0.2, 1)' }\n                }\n            }\n        }\n        <\/script>    <link href=\"\/advet\/assets\/css\/fonts.css\" rel=\"stylesheet\">\n            <link rel=\"icon\" href=\"\/advet\/assets\/uploads\/properties\/prop_69eb1280c70dd1.02437408.png\"\n            type=\"image\/png\">\n        <style>\n        :root {\n            --hero-accent:\n                #899178            ;\n        }\n\n        body {\n            background-color:\n                #ffffff            ;\n            color:\n                #2a2925            ;\n            -webkit-font-smoothing: antialiased;\n            -moz-osx-font-smoothing: grayscale;\n        }\n\n        .image-soft-clip {\n            clip-path: inset(0 round 2rem);\n        }\n\n        .reveal {\n            opacity: 0;\n            transform: translateY(30px);\n            animation: soft-reveal 1.2s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;\n        }\n\n        @keyframes soft-reveal {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        input:focus,\n        textarea:focus,\n        select:focus {\n            outline: none;\n        }\n    <\/style>\n    <!-- Premium Navigation Styles for All Pages -->\n    <link rel=\"stylesheet\"\n        href=\"\/advet\/assets\/css\/hero-redesign.css?v=1778314959\">\n    <\/head>\n\n<body class=\"font-sans font-light min-h-screen flex flex-col selection:bg-accent selection:text-white\">\n\n    \n            <nav class=\"hero-nav\" style=\"position: absolute; width: 100%; top: 0; left: 0; z-index: 1000; padding: 2.5rem 6%;\">\n            <!-- Unified Brand Logo -->\n            <a href=\"\/advet\/\" class=\"hero-logo-container\">\n                <div class=\"hero-logo-icon\">\n                                            <img src=\"\/advet\/assets\/uploads\/properties\/prop_69eb1792701c50.35535330.png\" alt=\"Icon\">\n                                    <\/div>\n                <div class=\"hero-logo-text\"\n                    style=\"color: #2a2925\">\n                    <span class=\"font-bold\">Advet<\/span> <span class=\"hero-logo-light\" style=\"color: inherit; opacity: 0.5;\">Buildwell<\/span>                <\/div>\n            <\/a>\n\n            <!-- Premium Central Menu -->\n            <div class=\"hero-nav-center hidden lg:flex\"\n                style=\"\">\n                                    <div class=\"hero-nav-item\">\n                                                    <a href=\"\/advet\/\" class=\"hero-nav-link\"\n                                style=\"color: #2a2925\">\n                                Home                            <\/a>\n                                            <\/div>\n                                    <div class=\"hero-nav-item\">\n                                                    <a class=\"hero-nav-link\" onclick=\"void(0)\"\n                                style=\"color: #2a2925\">\n                                Properties                                <svg class=\"w-2.5 h-2.5 opacity-50 transition-transform\" viewBox=\"0 0 24 24\" fill=\"none\"\n                                    stroke=\"currentColor\" stroke-width=\"3\">\n                                    <path d=\"M6 9l6 6 6-6\" \/>\n                                <\/svg>\n                            <\/a>\n                            <div class=\"hero-dropdown\">\n                                                                    <a href=\"\/advet\/all-properties\" class=\"hero-dropdown-link\">All Properties<\/a>\n                                                                    <a href=\"\/advet\/properties\" class=\"hero-dropdown-link\">Residential<\/a>\n                                                                    <a href=\"\/advet\/commercial\" class=\"hero-dropdown-link\">Commercial<\/a>\n                                                            <\/div>\n                                            <\/div>\n                                    <div class=\"hero-nav-item\">\n                                                    <a class=\"hero-nav-link\" onclick=\"void(0)\"\n                                style=\"color: #2a2925\">\n                                Projects                                <svg class=\"w-2.5 h-2.5 opacity-50 transition-transform\" viewBox=\"0 0 24 24\" fill=\"none\"\n                                    stroke=\"currentColor\" stroke-width=\"3\">\n                                    <path d=\"M6 9l6 6 6-6\" \/>\n                                <\/svg>\n                            <\/a>\n                            <div class=\"hero-dropdown\">\n                                                                    <a href=\"\/advet\/projects\" class=\"hero-dropdown-link\">Discovery Hub<\/a>\n                                                                    <a href=\"\/advet\/projects\/cosmos-green\" class=\"hero-dropdown-link\">Cosmos Green<\/a>\n                                                            <\/div>\n                                            <\/div>\n                                    <div class=\"hero-nav-item\">\n                                                    <a href=\"\/advet\/gallery\" class=\"hero-nav-link\"\n                                style=\"color: #2a2925\">\n                                Gallery                            <\/a>\n                                            <\/div>\n                                    <div class=\"hero-nav-item\">\n                                                    <a href=\"\/advet\/contact\" class=\"hero-nav-link\"\n                                style=\"color: #2a2925\">\n                                Contact Us                            <\/a>\n                                            <\/div>\n                            <\/div>\n\n            <!-- Right Controls -->\n            <div class=\"hero-nav-right flex items-center gap-4 lg:gap-6\">\n                <!-- Post Property CTA (Desktop) -->\n                                                        <a href=\"\/advet\/post-property\" class=\"hero-btn-couture group\" \n                       style=\"background: rgba(0,0,0,0.03); border-color: rgba(0,0,0,0.1);\">\n                        <div class=\"hero-btn-couture-content\">\n                            <span class=\"hero-btn-couture-label italic font-serif lowercase\" style=\"color: #2a2925\">Post Property<\/span>\n                            <div class=\"hero-btn-couture-icon\">\n                                <svg class=\"w-2.5 h-2.5 transition-transform duration-500 group-hover:rotate-90\" fill=\"none\"\n                                    stroke=\"currentColor\" stroke-width=\"3\" viewBox=\"0 0 24 24\">\n                                    <path d=\"M12 4.5v15m7.5-7.5h-15\" \/>\n                                <\/svg>\n                            <\/div>\n                        <\/div>\n                        <div class=\"hero-btn-couture-border\"><\/div>\n                    <\/a>\n                \n                                    <div class=\"hero-nav-item\">\n                        <div class=\"flex items-center gap-3 cursor-pointer group\">\n                            <div class=\"hero-nav-link hidden md:flex\"\n                                style=\"color: #2a2925; padding-right: 0.5rem;\">\n                                <span>My Profile<\/span>\n                                <svg class=\"w-2.5 h-2.5 opacity-50 transition-transform group-hover:rotate-180\"\n                                    viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\">\n                                    <path d=\"M6 9l6 6 6-6\" \/>\n                                <\/svg>\n                            <\/div>\n                            <div\n                                class=\"w-10 h-10 rounded-full bg-accent flex items-center justify-center font-bold text-xs text-white ring-2 ring-transparent group-hover:ring-accent\/30 transition-all overflow-hidden relative shrink-0\">\n                                                                    <img src=\"\/advet\/assets\/uploads\/properties\/prop_69e07e53df3f94.52766340.jpeg\" alt=\"Profile\"\n                                        class=\"w-full h-full object-cover\">\n                                                            <\/div>\n                        <\/div>\n\n                        <!-- Profile Dropdown -->\n                        <div class=\"hero-dropdown\" style=\"left: auto; right: 0; transform: translateY(10px);\">\n                            <div class=\"px-4 py-3 border-b border-white\/5 mb-2\">\n                                <p class=\"text-[10px] font-bold uppercase tracking-widest text-accent mb-0.5\">\n                                    admin                                <\/p>\n                                <p class=\"text-sm font-serif text-white truncate\">Ashish<\/p>\n                            <\/div>\n                            <a href=\"\/advet\/profile\" class=\"hero-dropdown-link flex items-center gap-3\">\n                                <svg class=\"w-4 h-4 opacity-50\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"\n                                    viewBox=\"0 0 24 24\">\n                                    <path\n                                        d=\"M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z\" \/>\n                                <\/svg>\n                                My Profile\n                            <\/a>\n                                                            <a href=\"\/advet\/admin\/listings.php\" class=\"hero-dropdown-link flex items-center gap-3\">\n                                    <svg class=\"w-4 h-4 opacity-50\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"\n                                        viewBox=\"0 0 24 24\">\n                                        <path\n                                            d=\"M2.25 21h19.5m-18-18v18m10.5-18v18m0-13.5h3.75m-3.75 3h3.75m-3.75 3h3.75m-3.75 3h3.75m-9-12h3.75m-3.75 3h3.75m-3.75 3h3.75m-3.75 3h3.75\" \/>\n                                    <\/svg>\n                                    My Listings\n                                <\/a>\n                                <a href=\"\/advet\/admin\/dashboard.php\" class=\"hero-dropdown-link flex items-center gap-3\">\n                                    <svg class=\"w-4 h-4 opacity-50\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"\n                                        viewBox=\"0 0 24 24\">\n                                        <path\n                                            d=\"M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z\" \/>\n                                    <\/svg>\n                                    Dashboard\n                                <\/a>\n                                                        <div class=\"h-px bg-white\/5 my-2\"><\/div>\n                            <a href=\"\/advet\/auth\/logout\"\n                                class=\"hero-dropdown-link flex items-center gap-3 text-red-400 hover:text-red-300\">\n                                <svg class=\"w-4 h-4 opacity-50\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"\n                                    viewBox=\"0 0 24 24\">\n                                    <path\n                                        d=\"M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75\" \/>\n                                <\/svg>\n                                Logout\n                            <\/a>\n                        <\/div>\n                    <\/div>\n                \n                <button id=\"hero-mobile-btn\"\n                    class=\"lg:hidden p-2 text-white bg-white\/10 rounded-xl backdrop-blur-md border border-white\/20\">\n                    <svg class=\"w-6 h-6\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                        <path d=\"M4 6h16M4 12h16M4 18h16\" \/>\n                    <\/svg>\n                <\/button>\n            <\/div>\n        <\/nav>\n    \n    <!-- Full-Screen Mobile Drawer -->\n    <div id=\"mobile-menu\"\n        class=\"hidden lg:hidden fixed inset-0 z-[100] translate-x-full transition-transform duration-500 ease-in-out pointer-events-auto\">\n        <div id=\"mobile-menu-close\" class=\"absolute inset-0 bg-black\/20 backdrop-blur-md\"><\/div>\n        <div\n            class=\"absolute right-0 top-0 bottom-0 w-[85%] max-w-sm bg-white shadow-2xl flex flex-col p-10 overflow-y-auto\">\n            <div class=\"flex items-center justify-between mb-12\">\n                <span class=\"text-xs font-bold uppercase tracking-[0.4em] text-accent\">Menu<\/span>\n                <button id=\"hero-mobile-close\"\n                    class=\"w-10 h-10 flex items-center justify-center rounded-2xl bg-black\/5 text-muted hover:text-foreground\">\n                    <svg class=\"w-5 h-5\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                        <path d=\"M18 6 6 18M6 6l12 12\" \/>\n                    <\/svg>\n                <\/button>\n            <\/div>\n\n                            <div class=\"flex items-center gap-4 mb-10 pb-10 border-b border-black\/5\">\n                    <div\n                        class=\"w-14 h-14 rounded-2xl bg-accent flex items-center justify-center font-bold text-lg text-foreground overflow-hidden relative shrink-0\">\n                                                    <img src=\"\/advet\/assets\/uploads\/properties\/prop_69e07e53df3f94.52766340.jpeg\" alt=\"Profile\" class=\"w-full h-full object-cover\">\n                                            <\/div>\n                    <div>\n                        <p class=\"text-[10px] font-bold uppercase tracking-widest text-accent mb-0.5\">admin                        <\/p>\n                        <p class=\"text-xl font-serif text-foreground truncate\">Ashish<\/p>\n                    <\/div>\n                <\/div>\n            \n            <div class=\"space-y-8\">\n                <!-- Post Property CTA (Mobile) -->\n                                    <a href=\"\/advet\/post-property\"\n                        class=\"flex items-center justify-center gap-3 w-full py-5 bg-accent text-white text-xs font-bold uppercase tracking-[0.2em] rounded-2xl shadow-xl transform active:scale-95 transition-all\">\n                        <svg class=\"w-4 h-4\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" viewBox=\"0 0 24 24\">\n                            <path d=\"M12 4.5v15m7.5-7.5h-15\" \/>\n                        <\/svg>\n                        Post Property\n                    <\/a>\n                \n                                    <div class=\"space-y-4\">\n                        <p class=\"text-[9px] uppercase tracking-[0.4em] text-muted\/40 font-bold\">Account<\/p>\n                        <div class=\"flex flex-col gap-5 pl-4 border-l border-black\/5\">\n                            <a href=\"\/advet\/profile\" class=\"text-xl font-serif font-light text-foreground\">My\n                                Profile<\/a>\n                                                            <a href=\"\/advet\/admin\/dashboard.php\"\n                                    class=\"text-xl font-serif font-light text-foreground\">Dashboard<\/a>\n                                <a href=\"\/advet\/admin\/crm.php\"\n                                    class=\"text-xl font-serif font-light text-foreground\">CRM Overview<\/a>\n                                                        <a href=\"\/advet\/auth\/logout\"\n                                class=\"text-xl font-serif font-light text-red-500\">Sign Out<\/a>\n                        <\/div>\n                    <\/div>\n                \n                                                            <a href=\"\/advet\/\"\n                            class=\"block text-2xl font-serif font-light text-foreground\">Home<\/a>\n                                                                                <div class=\"space-y-4\">\n                            <p class=\"text-[9px] uppercase tracking-[0.4em] text-muted\/40 font-bold\">Properties<\/p>\n                            <div class=\"flex flex-col gap-5 pl-4 border-l border-black\/5\">\n                                                                    <a href=\"\/advet\/all-properties\"\n                                        class=\"text-xl font-serif font-light text-foreground\">All Properties<\/a>\n                                                                    <a href=\"\/advet\/properties\"\n                                        class=\"text-xl font-serif font-light text-foreground\">Residential<\/a>\n                                                                    <a href=\"\/advet\/commercial\"\n                                        class=\"text-xl font-serif font-light text-foreground\">Commercial<\/a>\n                                                            <\/div>\n                        <\/div>\n                                                                                <div class=\"space-y-4\">\n                            <p class=\"text-[9px] uppercase tracking-[0.4em] text-muted\/40 font-bold\">Projects<\/p>\n                            <div class=\"flex flex-col gap-5 pl-4 border-l border-black\/5\">\n                                                                    <a href=\"\/advet\/projects\"\n                                        class=\"text-xl font-serif font-light text-foreground\">Discovery Hub<\/a>\n                                                                    <a href=\"\/advet\/projects\/cosmos-green\"\n                                        class=\"text-xl font-serif font-light text-foreground\">Cosmos Green<\/a>\n                                                            <\/div>\n                        <\/div>\n                                                                                <a href=\"\/advet\/gallery\"\n                            class=\"block text-2xl font-serif font-light text-foreground\">Gallery<\/a>\n                                                                                <a href=\"\/advet\/contact\"\n                            class=\"block text-2xl font-serif font-light text-foreground\">Contact Us<\/a>\n                                                <\/div>\n        <\/div>\n    <\/div>\n\n            <script>\n            (function () {\n                const btn = document.getElementById('hero-mobile-btn');\n                const mob = document.getElementById('mobile-menu');\n                const backdrop = document.getElementById('mobile-menu-close');\n                const closeBtn = document.getElementById('hero-mobile-close');\n\n                if (btn && mob) {\n                    btn.addEventListener('click', () => {\n                        mob.classList.remove('hidden'); \/\/ Ensure it's not hidden\n                        setTimeout(() => {\n                            mob.classList.remove('translate-x-full');\n                            mob.classList.add('translate-x-0');\n                        }, 10);\n                    });\n\n                    const closeMenu = () => {\n                        mob.classList.remove('translate-x-0');\n                        mob.classList.add('translate-x-full');\n                        setTimeout(() => mob.classList.add('hidden'), 500);\n                    }\n\n                    closeBtn?.addEventListener('click', closeMenu);\n                    backdrop?.addEventListener('click', closeMenu);\n                }\n            })();\n        <\/script>\n    \n    <main class=\"flex-grow pt-40 pb-32\">\n        <div class=\"max-w-7xl mx-auto px-6 sm:px-12 lg:px-16\">\n\n            <!-- Page Header -->\n            <div class=\"mb-16 reveal\">\n                <p class=\"text-xs font-medium uppercase tracking-widest text-accent mb-4\">All Properties<\/p>\n                <h1 class=\"text-5xl sm:text-7xl font-serif font-light leading-tight\">Property <span class=\"italic text-muted\">Listings<\/span><\/h1>\n            <\/div>\n\n            <!-- Redesigned Filter Command Bar -->\n            <div class=\"sticky top-24 z-50 mb-24 reveal reveal-delay-1 max-w-5xl mx-auto\">\n                <div class=\"bg-white\/70 backdrop-blur-2xl border border-white\/40 rounded-[2.5rem] shadow-[0_25px_60px_-15px_rgba(0,0,0,0.08)] p-3 md:p-4\">\n                    <form method=\"GET\" action=\"\/advet\/properties\" class=\"flex flex-col lg:flex-row items-stretch lg:items-center gap-3\">\n                        \n                        <!-- Search Section -->\n                        <div class=\"flex-grow flex items-center bg-surface\/50 rounded-2xl px-5 border border-sand\/20 group focus-within:bg-white focus-within:shadow-sm transition-all\">\n                            <svg class=\"w-4 h-4 text-muted\/40 group-focus-within:text-accent\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><circle cx=\"11\" cy=\"11\" r=\"8\"\/><path d=\"m21 21-4.3-4.3\"\/><\/svg>\n                            <input type=\"text\" name=\"search\" value=\"\" placeholder=\"Search neighborhood or project...\"\n                                   class=\"w-full bg-transparent text-sm py-4 px-4 outline-none placeholder:text-muted\/30 font-medium\">\n                                                    <\/div>\n\n                        <!-- Controls Wrapper -->\n                        <div class=\"flex flex-wrap md:flex-nowrap items-center gap-3\">\n                            \n                            <!-- Archetype Segment -->\n                            <div class=\"flex bg-surface\/50 p-1.5 rounded-2xl border border-sand\/20\">\n                                                                <a href=\"?cat=all&type=Buy&search=&min_price=0&max_price=0&bedrooms=0\" \n                                   class=\"px-5 py-2.5 rounded-xl text-[10px] uppercase font-bold tracking-widest transition-all text-muted\/60 hover:text-muted\">\n                                    All                                <\/a>\n                                                                <a href=\"?cat=Flat%2FApartment&type=Buy&search=&min_price=0&max_price=0&bedrooms=0\" \n                                   class=\"px-5 py-2.5 rounded-xl text-[10px] uppercase font-bold tracking-widest transition-all text-muted\/60 hover:text-muted\">\n                                    Residences                                <\/a>\n                                                                <a href=\"?cat=Plot&type=Buy&search=&min_price=0&max_price=0&bedrooms=0\" \n                                   class=\"px-5 py-2.5 rounded-xl text-[10px] uppercase font-bold tracking-widest transition-all text-muted\/60 hover:text-muted\">\n                                    Plots                                <\/a>\n                                                                <a href=\"?cat=Commercial&type=Buy&search=&min_price=0&max_price=0&bedrooms=0\" \n                                   class=\"px-5 py-2.5 rounded-xl text-[10px] uppercase font-bold tracking-widest transition-all text-muted\/60 hover:text-muted\">\n                                    Commercial                                <\/a>\n                                                            <\/div>\n\n                            <!-- Protocol Dropdown -->\n                            <div class=\"relative group\">\n                                <button type=\"button\" class=\"h-full bg-surface\/50 px-6 py-4 rounded-2xl border border-sand\/20 text-[10px] font-bold uppercase tracking-widest text-muted flex items-center gap-4 hover:bg-white hover:shadow-sm transition-all\">\n                                    <span>Buy\/Sell<\/span>\n                                    <svg class=\"w-2.5 h-2.5 opacity-40 transition-transform group-hover:rotate-180\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"3\"><path d=\"m6 9 6 6 6-6\"\/><\/svg>\n                                <\/button>\n                                <div class=\"absolute top-full left-0 lg:right-0 lg:left-auto mt-3 w-56 bg-white rounded-3xl shadow-2xl border border-sand\/10 opacity-0 translate-y-4 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all z-50 py-3 overflow-hidden\">\n                                                                        <a href=\"?cat=&type=all&search=&min_price=0&max_price=0&bedrooms=0\" \n                                       class=\"block px-8 py-3.5 text-[10px] uppercase tracking-widest font-bold transition-all text-muted\/60 hover:text-accent hover:bg-surface\">\n                                        Any Protocol                                    <\/a>\n                                                                        <a href=\"?cat=&type=Buy&search=&min_price=0&max_price=0&bedrooms=0\" \n                                       class=\"block px-8 py-3.5 text-[10px] uppercase tracking-widest font-bold transition-all text-accent bg-accent\/5\">\n                                        Buy\/Sell                                    <\/a>\n                                                                        <a href=\"?cat=&type=Rent&search=&min_price=0&max_price=0&bedrooms=0\" \n                                       class=\"block px-8 py-3.5 text-[10px] uppercase tracking-widest font-bold transition-all text-muted\/60 hover:text-accent hover:bg-surface\">\n                                        Rent\/Lease                                    <\/a>\n                                                                    <\/div>\n                            <\/div>\n\n                            <!-- Advanced Settings Trigger (Desktop Only for visual balance) -->\n                            <div class=\"relative group\">\n                                <button type=\"button\" class=\"h-full bg-foreground text-background px-6 py-4 rounded-2xl text-[10px] font-bold uppercase tracking-widest flex items-center gap-3 hover:bg-accent transition-all shadow-lg shadow-foreground\/10 group-hover:scale-[1.02]\">\n                                    <svg class=\"w-3.5 h-3.5\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><path d=\"M4 21v-7M4 10V3M12 21v-9M12 8V3M20 21v-5M20 12V3M1 14h6M9 8h6M17 16h6\"\/><\/svg>\n                                    Filters\n                                <\/button>\n                                \n                                <div class=\"absolute top-full right-0 mt-3 w-80 bg-white rounded-[2.5rem] shadow-2xl border border-sand\/10 opacity-0 translate-y-4 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all z-50 p-8\">\n                                    <div class=\"space-y-8\">\n                                        <div>\n                                            <p class=\"text-[9px] uppercase tracking-[0.2em] font-bold text-muted\/40 mb-5\">Price Range<\/p>\n                                            <div class=\"flex gap-3\">\n                                                <input type=\"number\" name=\"min_price\" value=\"\" placeholder=\"Min\" class=\"w-full px-5 py-3.5 bg-surface rounded-xl text-xs outline-none focus:bg-white border border-transparent focus:border-sand\/40 transition-all font-medium\">\n                                                <input type=\"number\" name=\"max_price\" value=\"\" placeholder=\"Max\" class=\"w-full px-5 py-3.5 bg-surface rounded-xl text-xs outline-none focus:bg-white border border-transparent focus:border-sand\/40 transition-all font-medium\">\n                                            <\/div>\n                                        <\/div>\n                                        \n                                        <div>\n                                            <p class=\"text-[9px] uppercase tracking-[0.2em] font-bold text-muted\/40 mb-5\">Minimal Beds<\/p>\n                                            <div class=\"flex flex-wrap gap-2\">\n                                                                                                <label class=\"cursor-pointer\">\n                                                    <input type=\"radio\" name=\"bedrooms\" value=\"0\" checked class=\"hidden peer\">\n                                                    <span class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-surface text-[10px] font-bold peer-checked:bg-accent peer-checked:text-white transition-all text-muted\/60 peer-checked:shadow-sm\">Any<\/span>\n                                                <\/label>\n                                                                                                <label class=\"cursor-pointer\">\n                                                    <input type=\"radio\" name=\"bedrooms\" value=\"1\"  class=\"hidden peer\">\n                                                    <span class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-surface text-[10px] font-bold peer-checked:bg-accent peer-checked:text-white transition-all text-muted\/60 peer-checked:shadow-sm\">1+<\/span>\n                                                <\/label>\n                                                                                                <label class=\"cursor-pointer\">\n                                                    <input type=\"radio\" name=\"bedrooms\" value=\"2\"  class=\"hidden peer\">\n                                                    <span class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-surface text-[10px] font-bold peer-checked:bg-accent peer-checked:text-white transition-all text-muted\/60 peer-checked:shadow-sm\">2+<\/span>\n                                                <\/label>\n                                                                                                <label class=\"cursor-pointer\">\n                                                    <input type=\"radio\" name=\"bedrooms\" value=\"3\"  class=\"hidden peer\">\n                                                    <span class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-surface text-[10px] font-bold peer-checked:bg-accent peer-checked:text-white transition-all text-muted\/60 peer-checked:shadow-sm\">3+<\/span>\n                                                <\/label>\n                                                                                                <label class=\"cursor-pointer\">\n                                                    <input type=\"radio\" name=\"bedrooms\" value=\"4\"  class=\"hidden peer\">\n                                                    <span class=\"w-10 h-10 flex items-center justify-center rounded-xl bg-surface text-[10px] font-bold peer-checked:bg-accent peer-checked:text-white transition-all text-muted\/60 peer-checked:shadow-sm\">4+<\/span>\n                                                <\/label>\n                                                                                            <\/div>\n                                        <\/div>\n\n                                        <div class=\"pt-4 border-t border-sand\/20\">\n                                            <button type=\"submit\" class=\"w-full py-4 bg-foreground text-background text-[10px] font-bold uppercase tracking-widest rounded-2xl hover:bg-accent transition-all\">Apply Refinements<\/button>\n                                            <a href=\"\/advet\/properties\" class=\"block text-center mt-4 text-[9px] uppercase tracking-widest font-bold text-muted\/40 hover:text-accent\">Reset all parameters<\/a>\n                                        <\/div>\n                                    <\/div>\n                                <\/div>\n                            <\